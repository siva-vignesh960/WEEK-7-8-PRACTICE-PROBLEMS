import java.util.Scanner;

public class FactorsProgram {

    // Method to find factors and store in array
    public static int[] getFactors(int n) {
        int count = 0;

        // First loop → count factors
        for (int i = 1; i <= n; i++) {
            if (n % i == 0) {
                count++;
            }
        }

        // Create array
        int[] factors = new int[count];

        // Second loop → store factors
        int index = 0;
        for (int i = 1; i <= n; i++) {
            if (n % i == 0) {
                factors[index++] = i;
            }
        }

        return factors;
    }

    // Method to find sum
    public static int getSum(int[] arr) {
        int sum = 0;
        for (int num : arr) {
            sum += num;
        }
        return sum;
    }

    // Method to find product
    public static int getProduct(int[] arr) {
        int product = 1;
        for (int num : arr) {
            product *= num;
        }
        return product;
    }

    // Method to find sum of squares
    public static double getSumOfSquares(int[] arr) {
        double sum = 0;
        for (int num : arr) {
            sum += Math.pow(num, 2);
        }
        return sum;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Input
        System.out.print("Enter a number: ");
        int n = sc.nextInt();

        // Get factors
        int[] factors = getFactors(n);

        // Display factors
        System.out.print("Factors are: ");
        for (int f : factors) {
            System.out.print(f + " ");
        }

        // Calculations
        int sum = getSum(factors);
        int product = getProduct(factors);
        double sumSquares = getSumOfSquares(factors);

        // Output
        System.out.println("\nSum of factors: " + sum);
        System.out.println("Product of factors: " + product);
        System.out.println("Sum of squares of factors: " + sumSquares);
    }
}